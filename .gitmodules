[submodule "modules/gfx_plugin/third_party/llvm-project"]
	path = modules/gfx_plugin/third_party/llvm-project
	url = https://github.com/llvm/llvm-project.git
[submodule "modules/gfx_plugin/third_party/clvk"]
	path = modules/gfx_plugin/third_party/clvk
