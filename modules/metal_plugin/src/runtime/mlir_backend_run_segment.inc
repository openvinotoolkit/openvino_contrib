std::vector<ov::Tensor> MlirBackend::Impl::run_segment(const Segment& seg, const std::vector<ov::Tensor>& inputs) {
        @autoreleasepool {
        auto run_fallback = [&](const char* reason) -> std::vector<ov::Tensor> {
            METAL_LOG_ERROR("fallback", std::string("[METAL MLIR] run_segment -> run_fallback: ") + (reason ? reason : "unknown"));
            if (!m_allow_partial_offload) {
                OPENVINO_THROW("METAL: CPU fallback is disabled in pure device mode");
            }
            ensure_fallback();
            OPENVINO_ASSERT(m_fallback_request, "Fallback request is null");
            OPENVINO_ASSERT(inputs.size() == m_fallback_inputs.size(), "Fallback: input count mismatch");
            for (size_t i = 0; i < inputs.size(); ++i) {
                m_fallback_request->set_input_tensor(i, inputs[i]);
            }
            m_fallback_request->infer();
            std::vector<ov::Tensor> res;
            res.reserve(m_fallback_outputs.size());
            for (size_t i = 0; i < m_fallback_outputs.size(); ++i) {
                auto tmp = m_fallback_request->get_output_tensor(i);
                ov::Tensor out(tmp.get_element_type(), tmp.get_shape());
                std::memcpy(out.data(), tmp.data(), tmp.get_byte_size());
                res.emplace_back(std::move(out));
            }
            return res;
        };

        // Ensure ops are present; if compile filled m_ir but not m_ops, sync them.
        if (m_ops.empty() && !m_ir.ops.empty()) {
            m_ops = m_ir.ops;
            m_segments.clear();
            m_segments.push_back(Segment{0, m_ops.size()});
        }

        if (seg.op_count == 0 || seg.first_op_index + seg.op_count > m_ops.size()) {
            METAL_LOG_DEBUG("mlir", "[METAL MLIR] run_segment guard failed; regenerating ops from IR");
            if (!m_ir.ops.empty()) {
                m_ops = m_ir.ops;
                m_segments.clear();
                m_segments.push_back(Segment{0, m_ops.size()});
            }
        }
        if (seg.op_count == 0 || seg.first_op_index + seg.op_count > m_ops.size()) {
            METAL_LOG_DEBUG("mlir", "[METAL MLIR] run_segment unable to recover ops → fallback");
            return run_fallback("bad segment bounds");
        }

        OPENVINO_ASSERT(m_pipelines.size() >= seg.first_op_index + seg.op_count && seg.op_count > 0,
                        "run_segment: pipelines were not generated by MLIR path");

        MetalBufferManager* mgr = m_active_mgr;
        if (!mgr) {
            m_owned_mgr = std::make_shared<MetalBufferManager>(m_device);
            mgr = m_owned_mgr.get();
        }
        OPENVINO_ASSERT(mgr, "MetalBufferManager is not available");

        struct ManagerGuard {
            MlirBackend::Impl* self;
            MetalBufferManager* prev = nullptr;
            void enter(MetalBufferManager* m) {
                if (self) {
                    prev = self->m_active_mgr;
                    self->m_active_mgr = m;
                }
            }
            ~ManagerGuard() {
                if (self) self->m_active_mgr = prev;
            }
        } guard{this};
        guard.enter(mgr);

        // Reuse main run() path to avoid duplicated allocation logic; run() now routes buffers via MetalBufferManager.
        std::vector<ov::Tensor> direct_outputs(m_original_model->outputs().size());
        run(inputs, direct_outputs);
        return direct_outputs;
        }  // @autoreleasepool
    }
