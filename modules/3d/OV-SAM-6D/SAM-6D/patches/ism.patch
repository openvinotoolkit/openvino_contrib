+def _parse_obj_id_from_cad(cad_path):
+    """Extract BOP object id from CAD filename, e.g. 'obj_000005.ply' -> 5.
+    Falls back to the last integer found in the basename. Returns 1 if none found.
+    """
+    name = os.path.basename(cad_path)
+    m = re.search(r'obj_(\d+)', name)
+    if m:
+        return int(m.group(1))
+    nums = re.findall(r'\d+', name)
+    return int(nums[-1]) if nums else 1
+
+
+def _parse_image_id_from_rgb(rgb_path):
+    """Extract image_id from sibling 'mask_visib/<image_id>_<inst>.png' if present.
+    Falls back to digits in the rgb filename, else 0.
+    """
+    scene_dir = os.path.dirname(os.path.abspath(rgb_path))
+    mask_dir = os.path.join(scene_dir, 'mask_visib')
+    if os.path.isdir(mask_dir):
+        for fname in sorted(os.listdir(mask_dir)):
+            m = re.match(r'(\d+)_\d+\.png$', fname)
+            if m:
+                return int(m.group(1))
+    nums = re.findall(r'\d+', os.path.basename(rgb_path))
+    return int(nums[-1]) if nums else 0
+
+
+def run_inference(segmentor_model, output_dir, cad_path, rgb_path, depth_path, cam_path, stability_score_thresh,
+                  obj_id=None, image_id=None, scene_id=0):
+    if obj_id is None:
+        obj_id = _parse_obj_id_from_cad(cad_path)
+    if image_id is None:
+        image_id = _parse_image_id_from_rgb(rgb_path)
+    logging.info(f"Using scene_id={scene_id}, image_id={image_id}, obj_id={obj_id}")
