-def weighted_procrustes(
-    src_points,
-    ref_points,
-    weights=None,
-    weight_thresh=0.0,
-    eps=1e-5,
-    return_transform=False,
-    src_centroid = None,
-    ref_centroid = None,
-):
-    r"""Compute rigid transformation from `src_points` to `ref_points` using weighted SVD.
