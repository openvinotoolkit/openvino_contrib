+
+ACT_LAYERS = {
+    'ReLU': nn.ReLU,
+    'LeakyReLU': nn.LeakyReLU,
+    'ELU': nn.ELU,
+    'GELU': nn.GELU,
+    'Sigmoid': nn.Sigmoid,
+    'Softplus': nn.Softplus,
+    'Tanh': nn.Tanh,
+    'Identity': nn.Identity,
+}
