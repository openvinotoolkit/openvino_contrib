+# ── Execution mode detection ────────────────────────────────────────────────────
+# Use ONNX-safe transforms when:
+#   1. FLASHOCC_OPENVINO_MODE=1 (explicit OpenVINO export)
+#   2. torch.onnx.is_in_onnx_export()=True (ONNX export in progress)
