-
-        Returns:
-            torch.Tensor: Transposed and gathered feats.
-        """
-        # (B, N_c, H, W) --> (B, H, W, N_c) --> (B, H*W, N_c)
-        feat = feat.permute(0, 2, 3, 1).contiguous()
-        feat = feat.view(feat.size(0), -1, feat.size(3))
-        feat = self._gather_feat(feat, ind)     # (B, K, N_c)
-        return feat
