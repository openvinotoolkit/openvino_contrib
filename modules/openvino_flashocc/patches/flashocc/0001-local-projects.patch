+# ── Execution mode detection ────────────────────────────────────────────────────
+# Use ONNX-safe transforms when:
+#   1. FLASHOCC_OPENVINO_MODE=1 (explicit OpenVINO export)
+#   2. torch.onnx.is_in_onnx_export()=True (ONNX export in progress)
+# Otherwise use CUDA-optimized path for training
+_USING_OPENVINO = os.getenv('FLASHOCC_OPENVINO_MODE', '0') == '1'
+
+
+def _inverse_se3_onnx(T: torch.Tensor) -> torch.Tensor:
+    """
+    ONNX-compatible inverse for batched SE(3) 4x4 transform matrices.
+
+    Mathematically equivalent to torch.linalg.inv(T) for orthogonal rotation matrices.
+    Uses the identity: T^-1 = [R^T | -R^T t; 0 | 1]
+
+    This decomposition avoids expensive full matrix inversion and produces ONNX-safe ops:
+      - torch.transpose() → ONNX transpose
+      - torch.cat() → ONNX concat
+      - matmul() → ONNX matmul
+
+    Args:
+        T (..., 4, 4): Batched SE(3) homogeneous transform matrices
+
+    Returns:
+        (..., 4, 4): Inverse transforms, numerically equivalent to torch.linalg.inv(T)
+    """
+    R = T[..., :3, :3]          # (..., 3, 3)
+    t = T[..., :3, 3:]          # (..., 3, 1)
+    Rt = R.transpose(-1, -2)    # R^T (since R is orthogonal: R^-1 = R^T)
+    top = torch.cat([Rt, -Rt.matmul(t)], dim=-1)   # (..., 3, 4)
+    bot = T[..., 3:, :]         # (..., 1, 4)  -- homogeneous row [0, 0, 0, 1]
+    return torch.cat([top, bot], dim=-2)            # (..., 4, 4)
+
