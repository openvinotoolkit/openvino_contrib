-                    'labels': labels        # (K', )
-                }
-        """
-        batch, cat, _, _ = heat.size()
-
-        # (B, K)
-        scores, inds, clses, ys, xs = self._topk(heat, K=self.max_num)
-
-        if reg is not None:
