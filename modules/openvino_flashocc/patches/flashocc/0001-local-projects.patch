+def _inverse_3x3_onnx(m: torch.Tensor, eps: float = 1e-6) -> torch.Tensor:
+    """ONNX-compatible batched 3x3 matrix inverse using pure arithmetic.
+    Works with ONNX opset 11+. m: (..., 3, 3)
+    """
+    a, b, c = m[..., 0, 0], m[..., 0, 1], m[..., 0, 2]
+    d, e, f = m[..., 1, 0], m[..., 1, 1], m[..., 1, 2]
+    g, h, i = m[..., 2, 0], m[..., 2, 1], m[..., 2, 2]
+    A  =  (e * i - f * h)
+    B_ = -(d * i - f * g)
+    C  =  (d * h - e * g)
+    D_ = -(b * i - c * h)
+    E  =  (a * i - c * g)
+    F  = -(a * h - b * g)
+    G  =  (b * f - c * e)
+    H  = -(a * f - c * d)
+    I  =  (a * e - b * d)
+    det = a * A + b * B_ + c * C
+    det = torch.where(det.abs() < eps, det + eps, det)
+    inv = torch.stack([A, D_, G, B_, E, H, C, F, I], dim=-1).reshape(m.shape)
+    return inv * (1.0 / det).unsqueeze(-1).unsqueeze(-1)
+
+
+def _use_onnx_bev_pool_fallback() -> bool:
+    return torch.onnx.is_in_onnx_export() and os.getenv("FLASHOCC_ONNX_FALLBACK", "0") == "1"
+
+
+def _bev_pool_v2_onnx_fallback(depth, feat, ranks_depth, ranks_feat, ranks_bev, bev_feat_shape):
+    """ONNX/OpenVINO-friendly BEV pooling using gather + mul + scatter_add.
+    depth: (B, N, D, H, W)
+    feat:  (B, N, H, W, C)
+    output: (B, C, Dz, Dy, Dx)
+    """
+    B, Dz, Dy, Dx, C = [int(v) for v in bev_feat_shape]
+
+    depth_flat = depth.reshape(-1)      # (B*N*D*H*W,)
+    feat_flat = feat.reshape(-1, C)     # (B*N*H*W, C)
+
+    rd = ranks_depth.long()
+    rf = ranks_feat.long()
+    rb = ranks_bev.long()
+
+    weighted = depth_flat[rd].unsqueeze(1) * feat_flat[rf]  # (P, C)
+
+    out = feat.new_zeros((B * Dz * Dy * Dx, C))
+    idx = rb.unsqueeze(1).expand(-1, C)
+    out = out.scatter_add(0, idx, weighted)
+
+    out = out.view(B, Dz, Dy, Dx, C).permute(0, 4, 1, 2, 3).contiguous()
+    return out
