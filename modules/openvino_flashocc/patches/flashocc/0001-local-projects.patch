-            img: PIL.Image
-            post_rot: Tensor (2, 2)
-            post_tran: Tensor (2, )
-        """
-        # adjust image
-        img = self.img_transform_core(img, resize_dims, crop, flip, rotate)
-
-        # post-homography transformation
-        # 将上述变换以矩阵表示.
-        post_rot *= resize
-        post_tran -= torch.Tensor(crop[:2])
-        if flip:
-            A = torch.Tensor([[-1, 0], [0, 1]])
-            b = torch.Tensor([crop[2] - crop[0], 0])
